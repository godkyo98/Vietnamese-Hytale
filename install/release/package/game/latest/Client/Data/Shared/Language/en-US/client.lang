builderTools.legend.MachinimaTool.Page9.SceneCommands = Scene: .mach scene [load | copy | rename]
builderTools.legend.MachinimaTool.Page9.ActorCommands = Actor: .mach actor [list | add | remove | set | model | move | clone | rotate | scale | clear]
builderTools.legend.MachinimaTool.Page9.EventCommands = Events: .mach event [list | add | remove]\n\
