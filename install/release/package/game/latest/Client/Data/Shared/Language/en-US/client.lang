builderTools.legend.SelectionTool.Page3.Title = Selection Commands
builderTools.legend.SelectionTool.Page3.BasicCommands = Basic Commands:\n\
- /set [Sets selection to blocks]\n\
- /clear [Clears all blocks in the selection]\n\
- /walls [Adds walls to selection]\n\
- /move [Moves the contents of the selection the direction you're facing]\n\
- /undo and /redo [Undo and Redo X times]\n\
- /copy [Copies the selection to clipboard]\n\
- /cut [Cuts the selection to clipboard]\n\
- /paste [Pastes clipboard at your position]\n\
- /stack [Stacks the selection in the direction you're facing X times]\n\
- /replace [Replace one material with another]\n\
- /hollow [Hollows out a shape leaving the center empty]\n\
- /flip [Mirror the blocks in the direction you're looking]\n\
- /rotate [Rotate the selection]\n\
- /expand [Expand the selection in the direction you're looking]\n\
- /contract [Shrink the selection by a distance]\n\
- /deselect [Clear the selection box]
builderTools.legend.SelectionTool.Page3.SeeHelpMenu = See the '/help' menu for more commands you can run on your selection!

builderTools.legend.RulerTool.Page1.Title = Basic Measurements
builderTools.legend.RulerTool.Page1.Description = The Ruler Tool allows you to measure distances between multiple points in 3D space, with support for multiple measurement lines.
