builderTools.legend.MachinimaTool.Page7.SetOrigin = Set scene origin to player position
builderTools.legend.MachinimaTool.Page7.OffsetToOrigin = Offset entire scene to player position

builderTools.legend.MachinimaTool.Page8.Title = Paths & Curves
builderTools.legend.MachinimaTool.Page8.Description = Choose how keyframes are interpolated:
builderTools.legend.MachinimaTool.Page8.LinearHeader = Linear (Default)
builderTools.legend.MachinimaTool.Page8.LinearDesc = Straight lines between keyframes. Simple and predictable movement.
builderTools.legend.MachinimaTool.Page8.BezierHeader = Bezier
builderTools.legend.MachinimaTool.Page8.BezierDesc = Smooth curves with control handles you can drag to shape the path.
builderTools.legend.MachinimaTool.Page8.SplineHeader = Spline
builderTools.legend.MachinimaTool.Page8.SplineDesc = Automatic smooth curves that pass through all keyframes.
builderTools.legend.MachinimaTool.Page8.BezierCommands = Path Commands:
builderTools.legend.MachinimaTool.Page8.EnableBezier = Enable bezier
builderTools.legend.MachinimaTool.Page8.SmoothBezier = Smooth handles
builderTools.legend.MachinimaTool.Page8.EnableSpline = Enable spline

