builderTools.legend.PaintBrush.Page2.AxisLockDescription = Cho phép bạn gắn chặt cọ vào một bề mặt phẳng, có thể di chuyển và xoay được. Các phím nóng sau đây cho phép bạn hiển thị, chỉnh sửa và thoát khỏi chế độ bề mặt.
builderTools.legend.PaintBrush.Page2.ShowSurfaceMoveTool = Hiện công cụ di chuyển bề mặt
builderTools.legend.PaintBrush.Page2.ShowSurfaceRotationTool = Hiện công cụ xoay bề mặt
builderTools.legend.PaintBrush.Page2.UseBrush = Sử dụng cọ
builderTools.legend.PaintBrush.Page2.ExitAxisLockMode = Thoát chế độ Khóa trục

builderTools.legend.CaveBrush.Page1.Title = [TMP] Cọ Hang Động
builderTools.legend.CaveBrush.Page1.Description = [TMP] Công cụ Cọ Hang Động cho phép bạn tạo ra các hang động và khe núi.
builderTools.legend.CaveBrush.Page1.DecorateArea = [TMP] Thêm trang trí hang động tại nơi bạn ngắm
builderTools.legend.CaveBrush.Page1.ShapeArea = [TMP] Điêu khắc khu vực hang động tại nơi bạn ngắm
builderTools.legend.CaveBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Hang Động:
builderTools.legend.CaveBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối tạo nên hang động bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.CaveBrush.Page2.Example1.Title = [TMP] Tạo Và Trang Trí Một Hang Động:
builderTools.legend.CaveBrush.Page2.Example1.Description = [TMP] 1. Nhìn vào mặt đất, sườn núi hoặc một khối đất liền.\n\
2. Giữ phím điêu khắc, thường là Chuột phải, để bắt đầu tạo hình dạng cho hang động.\n\
3. Trong hang động đã điêu khắc, nhìn vào sàn và giữ phím trang trí, thường là Chuột trái, để thêm vật trang trí.\n\
4. Trong hang động đã điêu khắc, nhìn lên trần và giữ phím trang trí, thường là Chuột trái, để thêm vật trang trí.\n\
5. Bây giờ bạn đã có một hang động với đầy đủ trang trí!
builderTools.legend.CaveBrush.Page3.Title = [TMP] Cài Đặt (1/2)
builderTools.legend.CaveBrush.Page3.CaveBlocks.Title = [TMP] Các Khối Hang Động:
builderTools.legend.CaveBrush.Page3.CaveBlocks.Description = [TMP] - Các khối dùng để tạo nên hang động.
builderTools.legend.CaveBrush.Page3.CaveBlockDecorations.Title = [TMP] Trang Trí Khối Hang Động:
builderTools.legend.CaveBrush.Page3.CaveBlockDecorations.Description = [TMP] - Các khối dùng để trang trí sàn hang động ở các phía của Khối Sàn. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.CaveBrush.Page3.TopDecorations.Title = [TMP] Trang Trí Phía Trên:
builderTools.legend.CaveBrush.Page3.TopDecorations.Description = [TMP] - Các khối dùng để trang trí trần hang động. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.CaveBrush.Page3.FloorBlocks.Title = [TMP] Các Khối Sàn:
builderTools.legend.CaveBrush.Page3.FloorBlocks.Description = [TMP] - Các khối dùng để trang trí sàn hang động. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.CaveBrush.Page3.FloorDecorations.Title = [TMP] Trang Trí Sàn:
builderTools.legend.CaveBrush.Page3.FloorDecorations.Description = [TMP] - Các khối được đặt làm vật trang trí trên các Khối Sàn. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.CaveBrush.Page3.OreBlocks.Title = [TMP] Các Khối Quặng:
builderTools.legend.CaveBrush.Page3.OreBlocks.Description = [TMP] - Các khối quặng để đặt xung quanh hang động. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.CaveBrush.Page4.Title = [TMP] Cài Đặt (2/2)
builderTools.legend.CaveBrush.Page4.Randomize.Title = [TMP] Ngẫu Nhiên:
builderTools.legend.CaveBrush.Page4.Randomize.Description = [TMP] - Khi được chọn, sẽ làm cho hình dạng nhỏ hơn hoặc lớn hơn một cách ngẫu nhiên khi tạo hình hang động.
builderTools.legend.CaveBrush.Page4.MeltStrength.Title = [TMP] Cường Độ Làm Tan:
builderTools.legend.CaveBrush.Page4.MeltStrength.Description = [TMP] - Điều khiển cường độ đục khoét của cọ. Cao hơn = xóa nhiều khối hơn, Thấp hơn = xóa ít khối hơn.
builderTools.legend.CaveBrush.Page4.SmoothStrength.Title = [TMP] Cường Độ Làm Mượt:
builderTools.legend.CaveBrush.Page4.SmoothStrength.Description = [TMP] - Điều khiển cường độ làm mượt của cọ. Cao hơn = mượt hơn, Thấp hơn = ít mượt hơn.

builderTools.legend.BoulderBrush.Page1.Title = [TMP] Cọ Đá Tảng
builderTools.legend.BoulderBrush.Page1.Description = [TMP] Công cụ Cọ Đá Tảng cho phép bạn tạo ra các tảng đá và cấu trúc đá.
builderTools.legend.BoulderBrush.Page1.DecorateArea = [TMP] Trang trí tảng đá tại nơi bạn ngắm
builderTools.legend.BoulderBrush.Page1.ShapeArea = [TMP] Đặt một tảng đá tại nơi bạn ngắm
builderTools.legend.BoulderBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Tảng Đá:
builderTools.legend.BoulderBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối tạo nên tảng đá bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.BoulderBrush.Page2.Example1.Title = [TMP] Tạo Và Trang Trí Một Tảng Đá:
builderTools.legend.BoulderBrush.Page2.Example1.Description = [TMP] 1. Nhìn vào mặt đất.\n\
2. Nhấn phím đặt, thường là Chuột phải, để đặt một tảng đá.\n\
3. Thay đổi Gốc thành Trung tâm.\n\
4. Nhìn vào tảng đá và nhấn phím trang trí, thường là Chuột trái, để thêm vật trang trí.\n\
5. Bây giờ bạn đã có một tảng đá với đầy đủ trang trí!
builderTools.legend.BoulderBrush.Page3.Title = [TMP] Cài Đặt (1/2)
builderTools.legend.BoulderBrush.Page3.RockBlocks.Title = [TMP] Các Khối Đá:
builderTools.legend.BoulderBrush.Page3.RockBlocks.Description = [TMP] - Các khối dùng để tạo nên tảng đá.
builderTools.legend.BoulderBrush.Page3.TopBlocks.Title = [TMP] Các Khối Phía Trên:
builderTools.legend.BoulderBrush.Page3.TopBlocks.Description = [TMP] - Các khối dùng để trang trí phần đỉnh của tảng đá. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.BoulderBrush.Page3.TopDecor.Title = [TMP] Trang Trí Phía Trên:
builderTools.legend.BoulderBrush.Page3.TopDecor.Description = [TMP] - Các khối được đặt trên các Khối Phía Trên. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.BoulderBrush.Page3.RockDecor.Title = [TMP] Trang Trí Đá:
builderTools.legend.BoulderBrush.Page3.RockDecor.Description = [TMP] - Các khối được đặt trên các Khối Đá. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.BoulderBrush.Page3.BoulderPoints.Title = [TMP] Các Điểm Tảng Đá:
builderTools.legend.BoulderBrush.Page3.BoulderPoints.Description = [TMP] - Số lượng tảng đá phụ được sử dụng để tạo nên tảng đá chính. Các tảng đá phụ có thể được giãn cách bằng Bán kính Tảng đá để tạo thành một tảng đá duy nhất hoặc một nhóm đá.
builderTools.legend.BoulderBrush.Page3.BoulderRadius.Title = [TMP] Bán Kính Tảng Đá:
builderTools.legend.BoulderBrush.Page3.BoulderRadius.Description = [TMP] - Điều khiển khoảng cách giữa các Điểm Tảng Đá. Điều này có thể được dùng để làm tảng đá rộng hơn hoặc tạo ra một nhóm đá.
builderTools.legend.BoulderBrush.Page4.Title = [TMP] Cài Đặt (2/2)
builderTools.legend.BoulderBrush.Page4.Randomization.Title = [TMP] Độ Ngẫu Nhiên:
builderTools.legend.BoulderBrush.Page4.Randomization.Description = [TMP] - Điều khiển mức độ ngẫu nhiên của tảng đá. Cao hơn = ngẫu nhiên hơn, Thấp hơn = ít ngẫu nhiên hơn.
builderTools.legend.BoulderBrush.Page4.Smoothness.Title = [TMP] Độ Mượt:
builderTools.legend.BoulderBrush.Page4.Smoothness.Description = [TMP] - Điều khiển độ mượt của tảng đá. Cao hơn = mượt hơn, Thấp hơn = ít mượt hơn.
builderTools.legend.BoulderBrush.Page4.StackSize.Title = [TMP] Kích Thước Xếp Chồng (Nâng Cao):
builderTools.legend.BoulderBrush.Page4.StackSize.Description = [TMP] - Điều khiển số lần xếp chồng tảng đá dựa trên Chiều rộng của nó. Đây là một cách khác để tạo hình tảng đá. Tảng đá sẽ đặt hình dạng hiện tại xuống, di chuyển nó lên theo Chiều cao, giảm Chiều rộng, rồi tiếp tục đặt và lặp lại quá trình này.
builderTools.legend.BoulderBrush.Page4.StackRandomization.Title = [TMP] Độ Ngẫu Nhiên Xếp Chồng (Nâng Cao):
builderTools.legend.BoulderBrush.Page4.StackRandomization.Description = [TMP] - Độ ngẫu nhiên giữa các lớp chiều cao của tảng đá. Cao hơn = ngẫu nhiên hơn, Thấp hơn = ít ngẫu nhiên hơn.
builderTools.legend.BoulderBrush.Page4.StackTip.Title = [TMP] Mẹo Cài Đặt Nâng Cao:
builderTools.legend.BoulderBrush.Page4.StackTip.Description = [TMP] - Để xem cách Kích thước Xếp chồng và Độ ngẫu nhiên Xếp chồng hoạt động, hãy chỉnh Độ mượt thành 0, Hình dạng thành Khối lập phương, Kích thước Xếp chồng trên 0, và thử các giá trị Chiều rộng và Chiều cao khác nhau.

builderTools.legend.BuildingBrush.Page1.Title = [TMP] Cọ Xây Dựng
builderTools.legend.BuildingBrush.Page1.Description = [TMP] Công cụ Cọ Xây Dựng cho phép bạn tạo ra các tòa nhà và hình thành các cấu trúc.
builderTools.legend.BuildingBrush.Page1.ShapeArea = [TMP] Đặt một tòa nhà tại nơi bạn ngắm
builderTools.legend.BuildingBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Tòa Nhà:
builderTools.legend.BuildingBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối tạo nên tòa nhà bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.BuildingBrush.Page2.Example1.Title = [TMP] Tạo Một Tòa Tháp Có Cửa Sổ:
builderTools.legend.BuildingBrush.Page2.Example1.Description = [TMP] 1. Sử dụng các cài đặt để điều chỉnh Chiều rộng và Chiều cao theo ý muốn.\n\
2. Thay đổi Số tầng thành số lượng tầng mà bạn muốn tòa tháp có.\n\
3. Thay đổi Số lượng cửa sổ theo ý muốn, và thay đổi Bán kính cửa sổ để chúng được đặt đúng vị trí trên tường. Việc đặt cửa sổ đúng vị trí hiện tại cần phải thử nghiệm nhiều lần.\n\
4. Thay đổi cài đặt Mái nhà theo ý muốn.\n\
5. Nhấn phím đặt, thường là Chuột phải, để đặt tòa nhà.\n\
6. Bây giờ bạn đã có một tòa tháp!
builderTools.legend.BuildingBrush.Page3.Title = [TMP] Cài Đặt
builderTools.legend.BuildingBrush.Page3.MainBlock.Title = [TMP] Khối Chính:
builderTools.legend.BuildingBrush.Page3.MainBlock.Description = [TMP] - Các khối chính dùng để tạo nên tòa nhà.
builderTools.legend.BuildingBrush.Page3.SecondaryBlock.Title = [TMP] Khối Phụ:
builderTools.legend.BuildingBrush.Page3.SecondaryBlock.Description = [TMP] - Các khối được sử dụng làm vật trang trí chạy dọc giữa các bức tường của tòa nhà.
builderTools.legend.BuildingBrush.Page3.FloorBlock.Title = [TMP] Khối Sàn:
builderTools.legend.BuildingBrush.Page3.FloorBlock.Description = [TMP] - Các khối được sử dụng để làm sàn trong tòa nhà.
builderTools.legend.BuildingBrush.Page3.EnableWindows.Title = [TMP] Kích Hoạt Cửa Sổ:
builderTools.legend.BuildingBrush.Page3.EnableWindows.Description = [TMP] - Cho phép đặt cửa sổ lên tòa nhà.
builderTools.legend.BuildingBrush.Page3.WindowRadius.Title = [TMP] Bán Kính Cửa Sổ:
builderTools.legend.BuildingBrush.Page3.WindowRadius.Description = [TMP] - Bán kính nơi cửa sổ sẽ được đặt. Thiết lập này có thể cần điều chỉnh nhiều lần để có kết quả chính xác.
builderTools.legend.BuildingBrush.Page3.EnableRoof.Title = [TMP] Kích Hoạt Mái Nhà:
builderTools.legend.BuildingBrush.Page3.EnableRoof.Description = [TMP] - Cho phép đặt mái nhà lên tòa nhà. Tắt mái nhà sẽ rất hữu ích khi bạn muốn tạo các bức tường.

builderTools.legend.DecorationBrush.Page1.Title = [TMP] Cọ Trang Trí
builderTools.legend.DecorationBrush.Page1.Description = [TMP] Công cụ Cọ Trang Trí cho phép bạn sơn các vật trang trí.
builderTools.legend.DecorationBrush.Page1.DecorateArea = [TMP] Xóa các khối khớp với danh sách Khối Cần Xóa.
builderTools.legend.DecorationBrush.Page1.ShapeArea = [TMP] Sơn các vật trang trí tại nơi bạn ngắm
builderTools.legend.DecorationBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Vật Trang Trí:
builderTools.legend.DecorationBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối được dùng để trang trí bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.DecorationBrush.Page2.Example1.Title = [TMP] Dọn Dẹp Một Khu Vực Và Thêm Trang Trí Mặt Đất:
builderTools.legend.DecorationBrush.Page2.Example1.Description = [TMP] 1. Tìm một khu vực mà bạn muốn thêm vật trang trí.\n\
2. Giữ phím dọn dẹp, thường là Chuột trái, để xóa các khối khỏi khu vực đó.\n\
3. Mở phần cài đặt và thêm bất kỳ vật trang trí nào bạn muốn.\n\
4. Giữ phím sơn, thường là Chuột phải, để sơn các vật trang trí lên khu vực đó.\n\
5. Bây giờ bạn đã trang trí xong khu vực!
builderTools.legend.DecorationBrush.Page3.Title = [TMP] Cài Đặt
builderTools.legend.DecorationBrush.Page3.BlocksToClear.Title = [TMP] Khối Cần Xóa:
builderTools.legend.DecorationBrush.Page3.BlocksToClear.Description = [TMP] - Các khối sẽ bị xóa khi sử dụng phím xóa khối, thường là Chuột trái.
builderTools.legend.DecorationBrush.Page3.FloorBlocks.Title = [TMP] Các Khối Sàn:
builderTools.legend.DecorationBrush.Page3.FloorBlocks.Description = [TMP] - Các khối dùng để trang trí. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.DecorationBrush.Page3.DecorationBlocks.Title = [TMP] Các Khối Trang Trí:
builderTools.legend.DecorationBrush.Page3.DecorationBlocks.Description = [TMP] - Các khối được đặt trên các Khối Sàn. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.

builderTools.legend.ForestBrush.Page1.Title = [TMP] Cọ Rừng
builderTools.legend.ForestBrush.Page1.Description = [TMP] Công cụ Cọ Rừng cho phép bạn tạo ra các khu rừng và bụi cây lá xum xuê.
builderTools.legend.ForestBrush.Page1.DecorateArea = [TMP] Thêm loại trang trí đã chọn tại nơi bạn ngắm
builderTools.legend.ForestBrush.Page1.ShapeArea = [TMP] Sơn mặt đất tại nơi bạn ngắm
builderTools.legend.ForestBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Khu Rừng:
builderTools.legend.ForestBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối tạo nên khu rừng bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.ForestBrush.Page2.Example1.Title = [TMP] Tạo Và Trang Trí Một Khu Rừng:
builderTools.legend.ForestBrush.Page2.Example1.Description = [TMP] 1. Nhìn vào khu vực bạn muốn tạo rừng.\n\
2. Giữ phím sơn mặt đất, thường là Chuột phải, để bắt đầu sơn sàn rừng.\n\
3. Thêm trang trí mặt đất bằng cách đổi loại thành Tán lá, và thêm các khối bạn muốn dùng cho cây cối vào phần Khối Tán Lá.\n\
4. Giữ phím trang trí, thường là Chuột trái, để đặt các vật trang trí tán lá.\n\
5. Thêm cây bằng cách đổi loại thành Cây.\n\
6. Giữ phím trang trí, thường là Chuột trái, để đặt cây.\n\
7. Bây giờ bạn đã có một khu rừng!
builderTools.legend.ForestBrush.Page3.Title = [TMP] Cài Đặt
builderTools.legend.ForestBrush.Page3.NumDecorations.Title = [TMP] Số Lượng Vật Trang Trí:
builderTools.legend.ForestBrush.Page3.NumDecorations.Description = [TMP] - Số lượng vật trang trí cần đặt. Chỉ áp dụng khi Loại Trang Trí được đặt thành Cây hoặc Đá Tảng.
builderTools.legend.ForestBrush.Page3.DecorationSpacing.Title = [TMP] Khoảng Cách Vật Trang Trí:
builderTools.legend.ForestBrush.Page3.DecorationSpacing.Description = [TMP] - Khoảng cách giữa các vật trang trí được đặt. Chỉ áp dụng khi Loại Trang Trí được đặt thành Cây hoặc Đá Tảng.
builderTools.legend.ForestBrush.Page3.FloorBlocks.Title = [TMP] Các Khối Sàn:
builderTools.legend.ForestBrush.Page3.FloorBlocks.Description = [TMP] - Các khối dùng để trang trí sàn rừng. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.ForestBrush.Page3.FloorOutlineBlocks.Title = [TMP] Các Khối Đường Viền Sàn:
builderTools.legend.ForestBrush.Page3.FloorOutlineBlocks.Description = [TMP] - Các khối dùng để trang trí đường viền của sàn rừng. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.ForestBrush.Page3.FloorPatchBlocks.Title = [TMP] Các Khối Mảng Sàn:
builderTools.legend.ForestBrush.Page3.FloorPatchBlocks.Description = [TMP] - Các khối để đặt ngẫu nhiên khắp sàn rừng nhằm mục đích trang trí. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.ForestBrush.Page3.FoliageBlocks.Title = [TMP] Các Khối Tán Lá:
builderTools.legend.ForestBrush.Page3.FoliageBlocks.Description = [TMP] - Các khối dùng cho tán lá trên sàn rừng. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra. Chỉ áp dụng khi Loại Trang Trí được đặt thành Tán lá.

builderTools.legend.MountainBrush.Page1.Title = [TMP] Cọ Núi
builderTools.legend.MountainBrush.Page1.Description = [TMP] Công cụ Cọ Núi cho phép bạn điêu khắc núi và địa hình.
builderTools.legend.MountainBrush.Page1.ShapeArea = [TMP] Điêu khắc một ngọn núi tại nơi bạn ngắm
builderTools.legend.MountainBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Núi:
builderTools.legend.MountainBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối tạo nên núi bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.MountainBrush.Page2.Example1.Title = [TMP] Tạo Một Ngọn Núi:
builderTools.legend.MountainBrush.Page2.Example1.Description = [TMP] 1. Nhìn vào mặt đất.\n\
2. Tùy chỉnh các khối để sử dụng cho núi bằng cách đặt các khối vào cài đặt Lớp.\n\
3. Giữ phím điêu khắc, thường là Chuột phải, để bắt đầu tạo hình dạng cho ngọn núi.\n\
4. Bây giờ bạn có thể điêu khắc các ngọn núi!
builderTools.legend.MountainBrush.Page2.Example2.Title = [TMP] Tạo Một Thung Lũng:
builderTools.legend.MountainBrush.Page2.Example2.Description = [TMP] 1. Nhìn vào mặt đất.\n\
2. Thay đổi Số lượng Điểm thành 1, và Khoảng cách Điểm lên trên 40.\n\
3. Giữ phím điêu khắc, thường là Chuột phải, để bắt đầu điêu khắc. Lưu ý rằng bây giờ bạn có 2 vị trí nơi địa hình đang được hình thành.\n\
4. Điêu khắc theo một đường thẳng di chuyển lên và xuống để tạo thành vách đá ở cả hai bên.\n\
5. Bây giờ bạn có thể điêu khắc một thung lũng! Khả năng này cũng có thể được dùng để tạo ra nhiều ngọn núi hoặc các chi tiết trong núi cùng một lúc.
builderTools.legend.MountainBrush.Page3.Title = [TMP] Cài Đặt
builderTools.legend.MountainBrush.Page3.TopLayer.Title = [TMP] Lớp Trên Cùng:
builderTools.legend.MountainBrush.Page3.TopLayer.Description = [TMP] - Các khối sẽ nằm ở phần trên cùng của địa hình.
builderTools.legend.MountainBrush.Page3.MiddleLayer.Title = [TMP] Lớp Giữa:
builderTools.legend.MountainBrush.Page3.MiddleLayer.Description = [TMP] - Các khối sẽ nằm ở phần giữa của địa hình.
builderTools.legend.MountainBrush.Page3.BottomLayer.Title = [TMP] Lớp Dưới Cùng:
builderTools.legend.MountainBrush.Page3.BottomLayer.Description = [TMP] - Các khối sẽ nằm ở phần dưới cùng của địa hình.
builderTools.legend.MountainBrush.Page3.NumberOfPoints.Title = [TMP] Số Lượng Điểm:
builderTools.legend.MountainBrush.Page3.NumberOfPoints.Description = [TMP] - Số lượng điểm được sử dụng để điêu khắc các ngọn núi.
builderTools.legend.MountainBrush.Page3.PointSpacing.Title = [TMP] Khoảng Cách Điểm:
builderTools.legend.MountainBrush.Page3.PointSpacing.Description = [TMP] - Khoảng cách giữa các Số lượng Điểm được sử dụng để điêu khắc núi.
builderTools.legend.MountainBrush.Page3.Smoothness.Title = [TMP] Độ Mượt:
builderTools.legend.MountainBrush.Page3.Smoothness.Description = [TMP] - Điều khiển độ mượt của địa hình được điêu khắc. Cao hơn = mượt hơn, thấp hơn = ít mượt hơn.

builderTools.legend.PathBrush.Page1.Title = [TMP] Cọ Lối Đi
builderTools.legend.PathBrush.Page1.Description = [TMP] Công cụ Cọ Lối Đi cho phép bạn tạo ra các lối đi.
builderTools.legend.PathBrush.Page1.DecorateArea = [TMP] Thêm các khối bậc thang gần những nơi thay đổi độ cao để làm lối đi mượt mà hơn
builderTools.legend.PathBrush.Page1.ShapeArea = [TMP] Vẽ một lối đi tại nơi bạn ngắm
builderTools.legend.PathBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Lối Đi:
builderTools.legend.PathBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối tạo nên lối đi bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.PathBrush.Page2.Example1.Title = [TMP] Tạo Một Lối Đi:
builderTools.legend.PathBrush.Page2.Example1.Description = [TMP] 1. Nhìn vào mặt đất.\n\
2. Tùy chỉnh các khối để sử dụng cho lối đi bằng cách đặt các khối vào phần cài đặt.\n\
3. Giữ phím vẽ, thường là Chuột phải, để bắt đầu vẽ lối đi.\n\
4. Giữ phím khối bậc thang, thường là Chuột trái, để đặt các khối bậc thang gần khu vực không bằng phẳng nhằm giúp chúng mượt mà hơn.\n\
5. Bây giờ bạn đã có một lối đi với đầy đủ trang trí!
builderTools.legend.PathBrush.Page3.Title = [TMP] Cài Đặt
builderTools.legend.PathBrush.Page3.PathBlocks.Title = [TMP] Các Khối Lối Đi:
builderTools.legend.PathBrush.Page3.PathBlocks.Description = [TMP] - Các khối chính dùng để tạo nên lối đi. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.PathBrush.Page3.OutlineBlocks.Title = [TMP] Các Khối Đường Viền:
builderTools.legend.PathBrush.Page3.OutlineBlocks.Description = [TMP] - Các khối dùng để đặt trên đường viền của lối đi. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng và thanh trượt Chiều rộng để điều chỉnh độ rộng của viền.
builderTools.legend.PathBrush.Page3.DecorationBlocks.Title = [TMP] Các Khối Trang Trí:
builderTools.legend.PathBrush.Page3.DecorationBlocks.Description = [TMP] - Các khối dùng để thêm vào làm vật trang trí dọc theo lối đi. Đi kèm với thanh trượt Mật độ để điều chỉnh số lượng và thanh trượt Chiều rộng để điều chỉnh độ rộng của khu vực trang trí.
builderTools.legend.PathBrush.Page3.HalfBlocks.Title = [TMP] Các Khối Bậc Thang Trên Lối Đi:
builderTools.legend.PathBrush.Page3.HalfBlocks.Description = [TMP] - Các khối bậc thang được đặt gần các khu vực không bằng phẳng để làm chúng mượt mà hơn.
builderTools.legend.PathBrush.Page3.ClearObstacles.Title = [TMP] Xóa Chướng Ngại Vật:
builderTools.legend.PathBrush.Page3.ClearObstacles.Description = [TMP] - Nếu được bật, nó sẽ loại bỏ các chướng ngại vật cản đường đi.

builderTools.legend.RiverBrush.Page1.Title = [TMP] Cọ Sông
builderTools.legend.RiverBrush.Page1.Description = [TMP] Công cụ Cọ Sông cho phép bạn tạo ra các dòng sông và đại dương.
builderTools.legend.RiverBrush.Page1.DecorateArea = [TMP] Thêm trang trí tại nơi bạn ngắm
builderTools.legend.RiverBrush.Page1.ShapeArea = [TMP] Vẽ một dòng sông tại nơi bạn ngắm
builderTools.legend.RiverBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Dòng Sông:
builderTools.legend.RiverBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối tạo nên dòng sông bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.RiverBrush.Page2.Example1.Title = [TMP] Tạo Một Dòng Sông/Thác Nước:
builderTools.legend.RiverBrush.Page2.Example1.Description = [TMP] 1. Nhìn vào một bề mặt.\n\
2. Tùy chỉnh các khối để sử dụng cho dòng sông bằng cách đặt các khối vào phần cài đặt.\n\
3. Giữ phím vẽ, thường là Chuột phải, để bắt đầu vẽ dòng sông.\n\
4. Giữ phím trang trí, thường là Chuột trái, để đặt các vật trang trí ở bên bờ sông, dưới mặt nước và trên mặt nước.\n\
5. Bây giờ bạn đã có một dòng sông hoặc thác nước!
builderTools.legend.RiverBrush.Page3.Title = [TMP] Cài Đặt
builderTools.legend.RiverBrush.Page3.FluidMaterial.Title = [TMP] Vật Liệu Chất Lỏng:
builderTools.legend.RiverBrush.Page3.FluidMaterial.Description = [TMP] - Vật liệu chất lỏng mà dòng sông sẽ được tạo thành.
builderTools.legend.RiverBrush.Page3.SurfaceBlocks.Title = [TMP] Các Khối Trên Chất Lỏng:
builderTools.legend.RiverBrush.Page3.SurfaceBlocks.Description = [TMP] - Các khối dùng để đặt bên bờ và dưới chất lỏng của dòng sông. Đi kèm với thanh trượt Mật độ để điều chỉnh số lượng và thanh trượt Chiều rộng để điều chỉnh độ rộng của khu vực đặt.
builderTools.legend.RiverBrush.Page3.SubsurfaceBlocks.Title = [TMP] Các Khối Dưới Chất Lỏng:
builderTools.legend.RiverBrush.Page3.SubsurfaceBlocks.Description = [TMP] - Các khối dùng để đặt dưới chất lỏng của dòng sông. Đi kèm với thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.RiverBrush.Page3.UnderDecorations.Title = [TMP] Trang Trí Dưới Chất Lỏng:
builderTools.legend.RiverBrush.Page3.UnderDecorations.Description = [TMP] - Các vật trang trí được thêm bên dưới chất lỏng. Đi kèm với thanh trượt Mật độ để kiểm soát số lượng đặt vào.
builderTools.legend.RiverBrush.Page3.SideDecorations.Title = [TMP] Trang Trí Bên Cạnh Chất Lỏng:
builderTools.legend.RiverBrush.Page3.SideDecorations.Description = [TMP] - Các vật trang trí để thêm vào bên bờ sông. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.
builderTools.legend.RiverBrush.Page3.TopDecorations.Title = [TMP] Trang Trí Trên Mặt Chất Lỏng:
builderTools.legend.RiverBrush.Page3.TopDecorations.Description = [TMP] - Các vật trang trí để thêm vào trên mặt sông. Đi kèm với một thanh trượt Mật độ để điều chỉnh số lượng đặt ra.

builderTools.legend.SpiralBrush.Page1.Title = [TMP] Cọ Xoắn Ốc
builderTools.legend.SpiralBrush.Page1.Description = [TMP] Công cụ Cọ Xoắn Ốc cho phép bạn tạo ra các hình xoắn ốc và các họa tiết hình tròn.
builderTools.legend.SpiralBrush.Page1.ShapeArea = [TMP] Đặt một hình xoắn ốc tại nơi bạn ngắm
builderTools.legend.SpiralBrush.Page2.BlockTip.Title = [TMP] Tùy Chỉnh Hình Xoắn Ốc:
builderTools.legend.SpiralBrush.Page2.BlockTip.Description = [TMP] Bạn có thể tùy chỉnh các khối tạo nên hình xoắn ốc bằng cách kéo và thả các khối từ túi đồ vào phần cài đặt.\n\nBạn cũng có thể xóa các khối bằng cách nhấp đúp vào chúng trong phần cài đặt.
builderTools.legend.SpiralBrush.Page2.Example1.Title = [TMP] Tạo Một Hình Xoắn Ốc Tùy Chỉnh:
builderTools.legend.SpiralBrush.Page2.Example1.Description = [TMP] 1. Nhìn vào một bề mặt.\n\
2. Tùy chỉnh các khối để sử dụng cho hình xoắn ốc bằng cách đặt các khối vào phần cài đặt.\n\
3. Thay đổi Số lượng Điểm theo nhu cầu của bạn. Cao hơn = nhiều điểm hơn trong hình xoắn ốc, Thấp hơn = ít điểm hơn.\n\
4. Thay đổi Bán kính thành 15. Điều này sẽ làm cho nó đủ rộng để thấy được chức năng của công cụ.\n\
5. Nếu bạn muốn hình xoắn ốc hướng lên trên, hãy thay đổi Khoảng cách Theo chiều dọc cao hơn 0.\n\
6. Thay đổi hướng vẽ hình xoắn ốc bằng cách tích vào các ô Lật, Xoay Hướng, hoặc Đảo Ngược Hướng.\n\
7. Bạn cũng có thể thêm độ mượt cho hình xoắn ốc bằng cách thay đổi Độ mượt cao hơn 0.\n\
8. Bạn cũng có thể chọn Làm rỗng Trung tâm để biến phần giữa của hình xoắn ốc thành không khí.\n\
9. Bây giờ bạn đã có một hình xoắn ốc!
builderTools.legend.SpiralBrush.Page3.Title = [TMP] Cài Đặt
builderTools.legend.SpiralBrush.Page3.NumberPoints.Title = [TMP] Số Lượng Điểm:
builderTools.legend.SpiralBrush.Page3.NumberPoints.Description = [TMP] - Số lượng điểm trên hình xoắn ốc.
builderTools.legend.SpiralBrush.Page3.Radius.Title = [TMP] Bán Kính:
builderTools.legend.SpiralBrush.Page3.Radius.Description = [TMP] - Bán kính của hình xoắn ốc, tương ứng với độ rộng của nó.
builderTools.legend.SpiralBrush.Page3.VerticalSpacing.Title = [TMP] Khoảng Cách Theo Chiều Dọc:
builderTools.legend.SpiralBrush.Page3.VerticalSpacing.Description = [TMP] - Khoảng cách giữa mỗi điểm trong hình xoắn ốc, tương ứng với độ cao của nó.
builderTools.legend.SpiralBrush.Page3.Flip.Title = [TMP] Lật
builderTools.legend.SpiralBrush.Page3.Flip.Description = [TMP] - Lật ngược thứ tự vẽ hình xoắn ốc.
builderTools.legend.SpiralBrush.Page3.RotateDirection.Title = [TMP] Xoay Hướng
builderTools.legend.SpiralBrush.Page3.RotateDirection.Description = [TMP] - Xoay hình xoắn ốc 180 độ.
builderTools.legend.SpiralBrush.Page3.InvertDirection.Title = [TMP] Đảo Ngược Hướng
builderTools.legend.SpiralBrush.Page3.InvertDirection.Description = [TMP] - Đảo ngược hướng vẽ của hình xoắn ốc.
builderTools.legend.SpiralBrush.Page3.Smoothness.Title = [TMP] Độ Mượt
builderTools.legend.SpiralBrush.Page3.Smoothness.Description = [TMP] - Điều khiển độ mượt của hình xoắn ốc. Cao hơn = mượt hơn, Thấp hơn = ít mượt hơn.
builderTools.legend.SpiralBrush.Page3.HollowCenter.Title = [TMP] Làm Rỗng Trung Tâm
builderTools.legend.SpiralBrush.Page3.HollowCenter.Description = [TMP] - Nếu được kích hoạt, sẽ thay thế phần trung tâm của hình xoắn ốc bằng không khí tính từ vị trí bạn nhấp chuột.

builderTools.legend.RevolveTool.Page1.Title = [TMP] Công Cụ Xoay Tròn
builderTools.legend.RevolveTool.Page1.Description = [TMP] Công cụ Xoay Tròn cho phép bạn xoay và dán một vùng chọn. Công cụ này chỉ hoạt động nếu một vùng chọn đã được tạo.
builderTools.legend.RevolveTool.Page1.ShapeArea = [TMP] Thực hiện việc xoay tròn. Tùy thuộc vào cài đặt bạn đang sử dụng, nó sẽ thực hiện xoay quanh nơi bạn đang ngắm hoặc quanh chính bạn.
builderTools.legend.RevolveTool.Page2.Example1.Title = [TMP] Xoay Tròn Với Cọ:
builderTools.legend.RevolveTool.Page2.Example1.Description = [TMP] 1. Tạo một vùng chọn mà bạn muốn xoay tròn.\n\
2. Trang bị Công cụ Xoay Tròn.\n\
3. Thiết lập các cài đặt theo ý muốn.\n\
4. Ngắm cọ vào nơi bạn muốn vùng chọn xoay quanh.\n\
5. Nhấn phím xoay, thường là Chuột phải.\n\
6. Bây giờ bạn đã xoay tròn vùng chọn của mình!
builderTools.legend.RevolveTool.Page2.Example2.Title = [TMP] Tạo Một Vòng Tròn Đầy Đủ Quanh Bản Thân:
builderTools.legend.RevolveTool.Page2.Example2.Description = [TMP] 1. Tạo một vùng chọn mà bạn muốn xoay tròn.\n\
2. Trang bị Công cụ Xoay Tròn.\n\
3. Tích chọn cài đặt Xoay Toàn Phần, và đổi Mục tiêu thành Người chơi (Bản thân).\n\
4. Di chuyển bản thân sao cho bạn cách vùng chọn một vài khối.\n\
5. Nhấn phím xoay, thường là Chuột phải.\n\
6. Bây giờ bạn đã xoay tròn hoàn toàn vùng chọn quanh chính mình!
builderTools.legend.RevolveTool.Page3.Title = [TMP] Cài Đặt
builderTools.legend.RevolveTool.Page3.Sampling.Title = [TMP] Chiến Lược Lấp Đầy:
builderTools.legend.RevolveTool.Page3.Sampling.Description = [TMP] - Chiến lược để lấp đầy các lỗ hổng khi xoay. Việc xoay đôi khi có thể để lại các lỗ hổng, cài đặt này sẽ cố gắng lấp đầy chúng.
builderTools.legend.RevolveTool.Page3.FullyRevolve.Title = [TMP] Xoay Toàn Phần:
builderTools.legend.RevolveTool.Page3.FullyRevolve.Description = [TMP] - Sẽ xoay vùng chọn hoàn toàn theo một hình tròn. Lựa chọn này sẽ bỏ qua Số lượng Dán và xoay toàn bộ vùng chọn.
builderTools.legend.RevolveTool.Page3.PlaceCount.Title = [TMP] Số Lượng Dán:
builderTools.legend.RevolveTool.Page3.PlaceCount.Description = [TMP] - Điều khiển số lần dán vùng chọn trong quá trình xoay. Ví dụ, nếu đặt là 5 thì vùng chọn sẽ được dán 5 lần.
builderTools.legend.RevolveTool.Page3.CenterAround.Title = [TMP] Tâm Xoay:
builderTools.legend.RevolveTool.Page3.CenterAround.Description = [TMP] - Điều khiển mục tiêu để xoay quanh. Mục tiêu Cọ = xoay quanh nơi cọ đang ngắm, Người chơi (Bản thân) = xoay quanh vị trí của bạn.
builderTools.legend.RevolveTool.Page3.UseCustomDistance.Title = [TMP] Sử Dụng Bán Kính Tùy Chỉnh:
builderTools.legend.RevolveTool.Page3.UseCustomDistance.Description = [TMP] - Dán và xoay vùng chọn tại nơi được ngắm, và sử dụng Bán kính Tùy chỉnh để điều chỉnh khoảng cách từ tâm.
builderTools.legend.RevolveTool.Page3.PlaceDistance.Title = [TMP] Bán Kính Tùy Chỉnh:
builderTools.legend.RevolveTool.Page3.PlaceDistance.Description = [TMP] - Bán kính để điều chỉnh khoảng cách giữa tâm và các điểm xoay. Cao hơn = rộng hơn, Thấp hơn = hẹp hơn.
builderTools.legend.RevolveTool.Page4.Title = [TMP] Cài Đặt (2/2)

builderTools.legend.LineBrush.Page1.Title = Cọ đường thẳng
builderTools.legend.LineBrush.Page1.Description = Cho phép bạn xây dựng các đường thẳng bằng khối
builderTools.legend.LineBrush.Page1.StartOrAddPoint = Bắt đầu hoặc thêm điểm vào đường thẳng
builderTools.legend.LineBrush.Page1.CancelLine = Hủy đường thẳng
builderTools.legend.LineBrush.Page1.SnapToAngles = Giữ để bật tính năng bắt dính vào các góc 45° khác nhau
builderTools.legend.LineBrush.Page1.EditInventoryProperties = Chỉnh sửa vật liệu, kích thước và các thuộc tính khác từ túi đồ

builderTools.legend.MachinimaTool.Page1.Title = Bắt đầu
builderTools.legend.MachinimaTool.Page1.Description = Tạo hoạt ảnh bằng khung hình chính (keyframe) sử dụng diễn viên, camera, hạt, âm thanh và nhiều thứ khác! Hoàn hảo cho các đoạn phim điện ảnh và cắt cảnh.
builderTools.legend.MachinimaTool.Page1.OpensMenu = Mở giao diện Trình chỉnh sửa Machinima
builderTools.legend.MachinimaTool.Page1.BaseCommand = Lệnh cơ sở cho tất cả các thao tác machinima
builderTools.legend.MachinimaTool.Page1.Scenes = Cảnh\n\
Một Cảnh là một thùng chứa cho machinima của bạn. Nó lưu trữ tất cả diễn viên, khung hình chính và cài đặt.
builderTools.legend.MachinimaTool.Page1.CreatingFirstScene = Tạo Cảnh đầu tiên của bạn\n\
1. Tìm một vị trí đẹp cho đoạn phim\n\
2. Mở Menu Machinima\n\
3. Nhấp vào biểu tượng + để tạo Cảnh mới\n\
4. Thêm Diễn viên đầu tiên của bạn!
builderTools.legend.MachinimaTool.Page1.Actors = Diễn viên\n\
Một Diễn viên là một đối tượng có thể hoạt ảnh hóa bằng khung hình chính. Xem trang tiếp theo để biết các loại diễn viên.
builderTools.legend.MachinimaTool.Page1.AddingCameraActor = Thêm Diễn viên Camera\n\
1. Định vị bản thân nơi bạn muốn đặt camera\n\
2. Mở Menu Machinima\n\
3. Nhấp vào biểu tượng + dưới danh sách cảnh\n\
4. Chọn "Camera" từ danh sách thả xuống\n\
5. Bây giờ bạn có thể nhấp vào camera để định vị lại, và nhấn C để chuyển sang góc nhìn camera!

builderTools.legend.MachinimaTool.Page2.Title = Các loại Diễn viên
builderTools.legend.MachinimaTool.Page2.Description = Các loại diễn viên khác nhau phục vụ các mục đích khác nhau trong phim của bạn. Chúng đều là các đối tượng có thể hoạt ảnh hóa, cho phép bạn kiểm soát vị trí, vòng xoay và các giá trị khác. Diễn viên được thêm thông qua Menu Machinima.
builderTools.legend.MachinimaTool.Page2.CameraHeader = Camera
builderTools.legend.MachinimaTool.Page2.CameraDesc = Cho phép bạn di chuyển camera dọc theo các đường dẫn và hoạt ảnh hóa các cài đặt khác nhau như FOV (tầm nhìn) và Tốc độ.
builderTools.legend.MachinimaTool.Page2.EntityHeader = Thực thể
builderTools.legend.MachinimaTool.Page2.EntityDesc = Các nhân vật hoạt ảnh có mô hình. Hỗ trợ xoay thân/đầu và các sự kiện hoạt ảnh.
builderTools.legend.MachinimaTool.Page2.PlayerHeader = Người chơi
builderTools.legend.MachinimaTool.Page2.PlayerDesc = Tương tự như Thực thể, nhưng tham chiếu đến người chơi địa phương.
builderTools.legend.MachinimaTool.Page2.ReferenceHeader = Tham chiếu
builderTools.legend.MachinimaTool.Page2.ReferenceDesc = Các điểm đánh dấu vô hình. Hữu ích cho việc nhắm mục tiêu và vị trí tham chiếu. Cho phép bạn đặt mục tiêu camera để theo dõi các điểm này.
builderTools.legend.MachinimaTool.Page2.ItemHeader = Vật phẩm
builderTools.legend.MachinimaTool.Page2.ItemDesc = Hiển thị các vật phẩm trong thế giới. Có thể được định vị và hoạt ảnh hóa.
builderTools.legend.MachinimaTool.Page2.AddActorCommand = Lệnh: .mach actor add [loại] [tên]\n\
Loại: camera, entity, player, ref, item

builderTools.legend.MachinimaTool.Page3.Title = Điều khiển Phát lại
builderTools.legend.MachinimaTool.Page3.Description = Các nút điều khiển phát lại cho phép bạn xem trước cảnh của mình bằng cách hoạt ảnh hóa tất cả diễn viên dọc theo đường dẫn khung hình chính của họ. Sử dụng chúng để tua thời gian, nhảy giữa các khung hình chính và thử nghiệm hoạt ảnh. Mỗi khung hình sẽ cập nhật tất cả diễn viên dọc theo đường dẫn của họ, chạy các hoạt ảnh.
builderTools.legend.MachinimaTool.Page3.TogglePause = Chuyển đổi Phát / Tạm dừng
builderTools.legend.MachinimaTool.Page3.ContinuousPlayback = Chuyển đổi Phát liên tục (lặp lại)
builderTools.legend.MachinimaTool.Page3.AutoRestart = Chuyển đổi Tự động bắt đầu lại khi kết thúc cảnh
builderTools.legend.MachinimaTool.Page3.RestartScene = Bắt đầu lại Cảnh từ đầu
builderTools.legend.MachinimaTool.Page3.EndScene = Nhảy đến khung hình cuối cùng
builderTools.legend.MachinimaTool.Page3.NavigationTitle = Điều hướng Khung hình:
builderTools.legend.MachinimaTool.Page3.FrameScrub = Tua qua các khung hình (giữ để tua liên tục)
builderTools.legend.MachinimaTool.Page3.JumpKeyframe = Nhảy đến điểm khung hình chính trước đó / tiếp theo
builderTools.legend.MachinimaTool.Page3.SpeedModifiers = Giữ SHIFT cho tốc độ x2, ALT cho tốc độ x0.5

builderTools.legend.MachinimaTool.Page4.Title = Chỉnh sửa Khung hình chính
builderTools.legend.MachinimaTool.Page4.Description = Khung hình chính định nghĩa vị trí, vòng xoay và cài đặt của diễn viên tại các thời điểm cụ thể. Hệ thống sẽ tự động nội suy giữa các khung hình chính để tạo ra các đường dẫn hoạt ảnh mượt mà. Thêm khung hình chính để tạo chuyển động, chỉnh sửa chúng để tinh chỉnh thời gian và vị trí.
builderTools.legend.MachinimaTool.Page4.AddKeyframe = Thêm khung hình chính mới vào cuối đường dẫn của diễn viên, kéo dài hoạt ảnh
builderTools.legend.MachinimaTool.Page4.AddAtCurrentFrame = Chèn một khung hình chính tại vị trí phát hiện tại
builderTools.legend.MachinimaTool.Page4.CopyKeyframe = Sao chép cài đặt khung hình chính đã chọn để dán vào diễn viên hoặc khung hình khác
builderTools.legend.MachinimaTool.Page4.DeleteKeyframe = Xóa khung hình chính bạn đang di chuột qua
builderTools.legend.MachinimaTool.Page4.EditKeyframe = Mở gizmo để điều chỉnh vị trí và vòng xoay của khung hình chính
builderTools.legend.MachinimaTool.Page4.MoveActor = Định vị lại toàn bộ đường dẫn của diễn viên như một khối thống nhất
builderTools.legend.MachinimaTool.Page4.EditFrameTime = Thay đổi thời điểm khung hình chính này xuất hiện trên dòng thời gian
builderTools.legend.MachinimaTool.Page4.AdjustFrameTime = Nhích thời gian khung hình chính sớm hơn hoặc muộn hơn

builderTools.legend.MachinimaTool.Page5.Title = Tương tác chuột
builderTools.legend.MachinimaTool.Page5.Description = Nhấp vào các nút khung hình chính trong thế giới để tương tác:
builderTools.legend.MachinimaTool.Page5.SelectKeyframe = Chọn khung hình chính (vào chế độ Di chuyển tự do)
builderTools.legend.MachinimaTool.Page5.JumpToKeyframe = Đặt làm hoạt động và nhảy đến khung hình
builderTools.legend.MachinimaTool.Page5.GizmoTitle = Điều khiển Gizmo:
builderTools.legend.MachinimaTool.Page5.TranslationGizmo = Mở Gizmo Dịch chuyển (khóa trục)
builderTools.legend.MachinimaTool.Page5.RotationGizmo = Mở Gizmo Xoay (đầu/thân)
builderTools.legend.MachinimaTool.Page5.FreeMoveTitle = Chế độ Di chuyển tự do:
builderTools.legend.MachinimaTool.Page5.FreeMoveDescription = Chuột trái để xác nhận vị trí, Chuột phải để hủy.\n\
Giữ SHIFT để bắt dính vào các bề mặt ở khoảng cách xa.\n\
Giữ ALT để bỏ qua việc bắt dính bề mặt.

builderTools.legend.MachinimaTool.Page6.Title = Chế độ lựa chọn
builderTools.legend.MachinimaTool.Page6.Description = Chế độ lựa chọn xác định cái gì sẽ được di chuyển khi bạn sử dụng các công cụ biến đổi. Chọn chế độ phù hợp dựa trên những gì bạn muốn định vị lại.
builderTools.legend.MachinimaTool.Page6.CycleMode = Chuyển đổi giữa các chế độ lựa chọn
builderTools.legend.MachinimaTool.Page6.KeyframeModeTitle = Chế độ Khung hình chính (Mặc định)
builderTools.legend.MachinimaTool.Page6.KeyframeModeDesc = Chỉ di chuyển khung hình chính được chọn. Sử dụng chế độ này để điều chỉnh chính xác từng điểm riêng lẻ dọc theo đường dẫn của diễn viên mà không ảnh hưởng đến các khung hình chính khác.
builderTools.legend.MachinimaTool.Page6.ActorModeTitle = Chế độ Diễn viên
builderTools.legend.MachinimaTool.Page6.ActorModeDesc = Di chuyển tất cả các khung hình chính của diễn viên đã chọn cùng nhau. Toàn bộ đường dẫn sẽ dịch chuyển như một đơn vị, giữ nguyên hình dạng của hoạt ảnh.
builderTools.legend.MachinimaTool.Page6.SceneModeTitle = Chế độ Cảnh
builderTools.legend.MachinimaTool.Page6.SceneModeDesc = Di chuyển toàn bộ gốc của cảnh, dịch chuyển tất cả diễn viên và đường dẫn của họ cùng nhau. Hữu ích cho việc di dời toàn bộ machinima của bạn sang một khu vực khác.

builderTools.legend.MachinimaTool.Page7.Title = Hiển thị & Gốc
builderTools.legend.MachinimaTool.Page7.DisplayTitle = Chuyển đổi Hiển thị:
builderTools.legend.MachinimaTool.Page7.ToggleDisplay = Chuyển đổi hiển thị lớp phủ trình chỉnh sửa
builderTools.legend.MachinimaTool.Page7.TogglePathNodes = Chuyển đổi hiển thị các nút đường dẫn
builderTools.legend.MachinimaTool.Page7.ToggleCamera = Bật/Tắt diễn viên camera
builderTools.legend.MachinimaTool.Page7.ToggleFrustum = Chuyển đổi hiển thị hình cụt của camera
builderTools.legend.MachinimaTool.Page7.OriginTitle = Điều khiển Gốc Cảnh:
builderTools.legend.MachinimaTool.Page7.GoToOrigin = Dịch chuyển đến gốc của cảnh
builderTools.legend.MachinimaTool.Page7.SetOrigin = Đặt gốc của cảnh tại vị trí người chơi
builderTools.legend.MachinimaTool.Page7.OffsetToOrigin = Bù trừ toàn bộ cảnh đến vị trí người chơi

builderTools.legend.MachinimaTool.Page8.Title = Đường dẫn & Đường cong
builderTools.legend.MachinimaTool.Page8.Description = Chọn cách các khung hình chính được nội suy:
builderTools.legend.MachinimaTool.Page8.LinearHeader = Tuyến tính (Mặc định)
builderTools.legend.MachinimaTool.Page8.LinearDesc = Các đường thẳng giữa các khung hình chính. Chuyển động đơn giản và có thể dự đoán được.
builderTools.legend.MachinimaTool.Page8.BezierHeader = Bezier
builderTools.legend.MachinimaTool.Page8.BezierDesc = Các đường cong mượt mà với các tay cầm điều khiển bạn có thể kéo để tạo hình đường dẫn.
builderTools.legend.MachinimaTool.Page8.SplineHeader = Spline
builderTools.legend.MachinimaTool.Page8.SplineDesc = Các đường cong mượt mà tự động đi qua tất cả các khung hình chính.
builderTools.legend.MachinimaTool.Page8.BezierCommands = Lệnh Đường dẫn:
builderTools.legend.MachinimaTool.Page8.EnableBezier = Bật bezier
builderTools.legend.MachinimaTool.Page8.SmoothBezier = Làm mượt tay cầm
builderTools.legend.MachinimaTool.Page8.EnableSpline = Bật spline

builderTools.legend.MachinimaTool.Page9.Title = Lệnh Console
builderTools.legend.MachinimaTool.Page9.SceneCommands = Cảnh: .mach scene [load | copy | rename]
builderTools.legend.MachinimaTool.Page9.ActorCommands = Diễn viên: .mach actor [list | add | remove | set | model | move | clone | rotate | scale | clear]
builderTools.legend.MachinimaTool.Page9.EventCommands = Sự kiện: .mach event [list | add | remove]\n\
Loại sự kiện: animation, camera, command, particle, target
builderTools.legend.MachinimaTool.Page9.FileCommands = Tệp: .mach save | load | files | autosave [giây]
builderTools.legend.MachinimaTool.Page9.UtilityCommands = Tiện ích: .mach tool | speed [giá trị] | align | restart

builderTools.legend.PasteTool.Page1.Title = Cọ dán cấu trúc (Prefab)
builderTools.legend.PasteTool.Page1.Description = Cho phép bạn dán nhanh các cấu trúc (prefab) như thể đang sử dụng một loại cọ. Hỗ trợ hầu hết các tính năng của Cọ vẽ.
builderTools.legend.PasteTool.Page1.LoadPrefabOrCopy = Tải một cấu trúc hoặc sao chép một vùng chọn
builderTools.legend.PasteTool.Page1.UseSelectionContents = Để sử dụng nội dung của một vùng chọn, hãy tạo vùng chọn bằng công cụ chọn và nhập '/copy', sau đó quay lại công cụ dán để sử dụng bản sao của bạn
builderTools.legend.PasteTool.Page1.OpensPrefabList = Mở danh sách cấu trúc; nhấp vào một cấu trúc để tải
builderTools.legend.PasteTool.Page1.PastePrefab = Dán cấu trúc; giữ để quét cấu trúc bằng cọ
builderTools.legend.PasteTool.Page1.StickPrefab = Gắn cấu trúc vào mục tiêu của bạn hoặc tách ra nếu đã gắn
builderTools.legend.PasteTool.Page1.RotatePrefabY = Xoay quanh trục Y
builderTools.legend.PasteTool.Page1.RotatePrefabX = Xoay quanh trục X
builderTools.legend.PasteTool.Page1.RotatePrefabZ = Xoay quanh trục Z
builderTools.legend.PasteTool.Page1.ShowTexture = Chuyển đổi vân bề mặt của các khối
builderTools.legend.PasteTool.Page1.CycleOrigin = Thay đổi điểm gốc (Dưới/Giữa/Trên)
builderTools.legend.PasteTool.Page2.Title = Các phím bổ trợ
builderTools.legend.PasteTool.Page2.ShiftPrefabLeftRight = Dịch cấu trúc sang trái hoặc phải
builderTools.legend.PasteTool.Page2.ShiftPrefabForwardBackward = Dịch cấu trúc tới hoặc lùi
builderTools.legend.PasteTool.Page2.ShiftPrefabUp = Dịch cấu trúc lên
builderTools.legend.PasteTool.Page2.ShiftPrefabDown = Dịch cấu trúc xuống
builderTools.legend.PasteTool.Page2.RotatePrefabLeftRight = Xoay cấu trúc sang trái hoặc phải
builderTools.legend.PasteTool.Page2.RollPrefabLeftRight = Lắc cấu trúc sang trái hoặc phải
builderTools.legend.PasteTool.Page2.RollPrefabForwardBackward = Lắc cấu trúc tới hoặc lùi
builderTools.legend.PasteTool.Page2.ResetShifting = Đặt lại việc dịch chuyển
builderTools.legend.PasteTool.Page2.ResetRotation = Đặt lại hướng xoay

builderTools.legend.TintBrush.Page1.Title = Cọ Nhuộm Màu
builderTools.legend.TintBrush.Page1.Description = Cho phép bạn sơn hoặc pha trộn các tông màu trên các khối.
builderTools.legend.TintBrush.Page1.BlendTints = Pha trộn các tông màu tại nơi bạn ngắm
builderTools.legend.TintBrush.Page1.PaintTints = Sơn màu của bạn tại nơi bạn ngắm
