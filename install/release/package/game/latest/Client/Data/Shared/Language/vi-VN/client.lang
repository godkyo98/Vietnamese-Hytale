builderTools.legend.BlockMaskAdjacent.Description = [TMP] Chỉ thay thế các khối nằm cạnh những khối trong danh sách này.
builderTools.legend.BlockMaskNeighbor.Title = [TMP] ^ Lân Cận:
builderTools.legend.BlockMaskNeighbor.Description = [TMP] Chỉ thay thế các khối chạm vào những khối trong danh sách này.

builderTools.legend.PaintBrush.Page1.Title = [TMP] Cọ Sơn
builderTools.legend.PaintBrush.Page1.Description = [TMP] Công cụ Cọ Sơn cho phép bạn đặt và xóa các khối với hình dạng, kích thước và vật liệu khác nhau.
builderTools.legend.PaintBrush.Page1.DestroyBlocks = Phá hủy các khối nơi bạn đang nhắm tới
builderTools.legend.PaintBrush.Page1.PlaceBlocks = Đặt các khối nơi bạn đang nhắm tới, theo vật liệu bạn đã thiết lập
builderTools.legend.PaintBrush.Page1.SelectTargetMaterial = Chọn vật liệu mục tiêu
builderTools.legend.PaintBrush.Page1.AddTargetMaterial = Thêm vật liệu mục tiêu làm đa vật liệu
builderTools.legend.PaintBrush.Page1.UndoLastBrush = Hoàn tác hành động cọ cuối cùng
builderTools.legend.PaintBrush.Page1.RedoLastUndo = Làm lại hành động vừa hoàn tác
builderTools.legend.PaintBrush.Page1.EditInventoryProperties = Chỉnh sửa vật liệu, kích thước, hình dạng và các thuộc tính khác từ túi đồ
builderTools.legend.PaintBrush.Page1.AirPlacementTitle = Đặt trên không
builderTools.legend.PaintBrush.Page1.AirPlacementHotkey = Chuyển đổi chế độ nhắm mục tiêu Đặt trên không
builderTools.legend.PaintBrush.Page1.AirPlacementDistanceChange = Thay đổi khoảng cách đặt trên không
